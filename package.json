{
  "name": "newtab-naivetab",
  "displayName": "NaiveTab - Visual Keyboard New Tab",
  "type": "module",
  "version": "2.6.0",
  "private": true,
  "packageManager": "pnpm@11.5.3",
  "description": "Visual keyboard for bookmarks & browser commands — one-press access. Drag & drop layout, full customization, focus mode, and cloud sync.",
  "scripts": {
    "site:dev": "vitepress dev site",
    "site:build": "vitepress build site",
    "site:preview": "vitepress preview site",
    "dev": "pnpm run clear && cross-env NODE_ENV=development run-p dev:*",
    "dev:prepare": "tsx scripts/prepare.ts",
    "dev:background": "pnpm run build:background -- --mode development",
    "dev:web": "vite",
    "dev:js": "pnpm run build:js -- --mode development",
    "build:prepare": "tsx scripts/prepare.ts",
    "build:web": "vite build",
    "build:js": "vite build --config vite.config.content.ts",
    "build:background": "vite build --config vite.config.background.ts",
    "build": "run-p build:chrome build:firefox",
    "build:debug": "cross-env NODE_ENV=production BROWSER=chrome NO_MINIFY=true run-s clear:chrome build:web build:js build:prepare build:background",
    "analyze": "cross-env ANALYZE=true pnpm run build:chrome",
    "build:chrome": "cross-env NODE_ENV=production BROWSER=chrome run-s clear:chrome build:web build:js build:prepare build:background",
    "build:firefox": "cross-env NODE_ENV=production BROWSER=firefox run-s clear:firefox build:web build:js build:prepare build:background",
    "pack": "run-p pack:chrome pack:firefox pack:source",
    "pack:chrome": "tsx scripts/pack-zip.ts extension-chrome ./dist/naivetab-chrome.zip",
    "pack:firefox": "tsx scripts/pack-zip.ts extension-firefox ./dist/naivetab-firefox.zip",
    "pack:source": "tsx scripts/pack-source.ts",
    "clear": "run-p clear:chrome clear:firefox clear:source",
    "clear:chrome": "rimraf extension-chrome dist/naivetab-chrome.zip",
    "clear:firefox": "rimraf extension-firefox dist/naivetab-firefox.zip",
    "clear:source": "rimraf dist/naivetab-source.zip",
    "release": "run-s build pack",
    "lint:fix": "eslint './src/**/*.{vue,ts}' --fix",
    "typecheck": "vue-tsc --noEmit",
    "test": "vitest test",
    "test:coverage": "vitest test --coverage",
    "check-patterns": "tsx scripts/check/check-patterns.ts",
    "postinstall": "simple-git-hooks"
  },
  "dependencies": {
    "axios": "^1.17.0",
    "cheerio": "^1.2.0",
    "crypto-js": "^4.2.0",
    "dayjs": "^1.11.21",
    "driver.js": "^1.4.0",
    "lunar-typescript": "^1.8.6",
    "reka-ui": "^2.9.10",
    "vue": "^3.5.38"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@iconify/json": "^2.2.485",
    "@iconify/vue": "^5.0.1",
    "@intlify/unplugin-vue-i18n": "^11.2.3",
    "@types/chrome": "^0.1.43",
    "@types/crypto-js": "^4.2.2",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^24.13.2",
    "@types/webextension-polyfill": "^0.12.5",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "^4.1.8",
    "@vue/compiler-sfc": "^3.5.38",
    "@vue/test-utils": "^2.4.11",
    "@vueuse/core": "^14.3.0",
    "archiver": "^8.0.0",
    "chokidar": "^5.0.0",
    "cross-env": "^10.1.0",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-vue": "^10.9.2",
    "fs-extra": "^11.3.5",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "kolorist": "^1.8.0",
    "lint-staged": "^16.4.0",
    "npm-run-all": "^4.1.5",
    "postcss-preset-env": "^11.3.0",
    "prettier": "^3.8.4",
    "rimraf": "^6.1.3",
    "rollup-plugin-visualizer": "^7.0.1",
    "simple-git-hooks": "^2.13.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^32.1.0",
    "unplugin-vue-markdown": "^30.0.0",
    "user-agent-data-types": "^0.4.3",
    "vite": "^8.0.16",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.8",
    "vue-demi": "^0.14.10",
    "vue-eslint-parser": "^10.4.1",
    "vue-i18n": "^11.4.5",
    "vue-tsc": "^3.3.4",
    "webextension-polyfill": "^0.12.0"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged && pnpm typecheck && pnpm test -- --run && pnpm exec tsx scripts/check/validate-registries.ts && pnpm check-patterns"
  },
  "lint-staged": {
    "*.{ts,js,vue}": [
      "eslint --fix"
    ]
  }
}
