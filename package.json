{
  "name": "newtab-naivetab",
  "displayName": "NaiveTab - Visual Keyboard New Tab",
  "type": "module",
  "version": "2.3.5",
  "private": true,
  "packageManager": "pnpm@11.2.2",
  "description": "Visual keyboard for bookmarks & browser commands — one-press access. Drag & drop layout, full customization, focus mode, and cloud sync.",
  "scripts": {
    "site:dev": "vitepress dev site",
    "site:build": "vitepress build site",
    "site:preview": "vitepress preview site",
    "dev": "pnpm run clear && cross-env NODE_ENV=development run-p dev:*",
    "dev:prepare": "esno scripts/prepare.ts",
    "dev:background": "pnpm run build:background -- --mode development",
    "dev:web": "vite",
    "dev:js": "pnpm run build:js -- --mode development",
    "build:prepare": "esno scripts/prepare.ts",
    "build:web": "vite build",
    "build:js": "vite build --config vite.config.content.ts",
    "build:background": "vite build --config vite.config.background.ts",
    "build": "run-p build:chrome build:firefox",
    "build:debug": "cross-env NODE_ENV=production BROWSER=chrome NO_MINIFY=true run-s clear:chrome build:web build:js build:prepare build:background",
    "build:chrome": "cross-env NODE_ENV=production BROWSER=chrome run-s clear:chrome build:web build:js build:prepare build:background",
    "build:firefox": "cross-env NODE_ENV=production BROWSER=firefox run-s clear:firefox build:web build:js build:prepare build:background",
    "pack": "run-p pack:chrome pack:firefox pack:source",
    "pack:chrome": "jszip-cli add extension-chrome/* -o ./dist/naivetab-chrome.zip --ignore '.DS_Store' -f",
    "pack:firefox": "jszip-cli add extension-firefox/* -o ./dist/naivetab-firefox.zip --ignore '.DS_Store' -f",
    "pack:source": "esno scripts/package-source.ts",
    "clear": "run-p clear:chrome clear:firefox clear:source",
    "clear:chrome": "rimraf extension-chrome dist/naivetab-chrome.zip",
    "clear:firefox": "rimraf extension-firefox dist/naivetab-firefox.zip",
    "clear:source": "rimraf dist/naivetab-source.zip",
    "release": "run-s build pack",
    "lint:fix": "eslint './src/**/*.{vue,ts}' --fix",
    "typecheck": "vue-tsc --noEmit",
    "test": "vitest test",
    "test:coverage": "vitest test --coverage",
    "postinstall": "simple-git-hooks"
  },
  "dependencies": {
    "@intlify/unplugin-vue-i18n": "^11.2.3",
    "axios": "^1.16.1",
    "cheerio": "^1.2.0",
    "crypto-js": "^4.2.0",
    "dayjs": "^1.11.20",
    "driver.js": "^1.4.0",
    "lunar-typescript": "^1.8.6",
    "naive-ui": "^2.44.1",
    "uuid": "^14.0.0",
    "vue": "^3.5.34",
    "vue-virtual-scroller": "2.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@ffflorian/jszip-cli": "^3.16.2",
    "@iconify/json": "^2.2.477",
    "@iconify/vue": "^5.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/chrome": "^0.1.42",
    "@types/crypto-js": "^4.2.2",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^24.12.4",
    "@types/webextension-polyfill": "^0.12.5",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "^4.1.7",
    "@vue/compiler-sfc": "^3.5.34",
    "@vue/test-utils": "^2.4.10",
    "@vueuse/core": "^14.3.0",
    "chokidar": "^5.0.0",
    "cross-env": "^10.1.0",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-vue": "^10.9.1",
    "esno": "^4.8.0",
    "fs-extra": "^11.3.5",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "kolorist": "^1.8.0",
    "lint-staged": "^16.4.0",
    "npm-run-all": "^4.1.5",
    "postcss-preset-env": "^11.3.0",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "rollup-plugin-visualizer": "^7.0.1",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-icons": "^23.0.1",
    "unplugin-vue-components": "^32.1.0",
    "unplugin-vue-markdown": "^30.0.0",
    "user-agent-data-types": "^0.4.3",
    "vite": "^8.0.14",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.7",
    "vue-demi": "^0.14.10",
    "vue-eslint-parser": "^10.4.0",
    "vue-i18n": "^11.4.4",
    "vue-tsc": "^3.3.1",
    "web-ext": "^10.2.0",
    "webext-bridge": "^6.0.1",
    "webextension-polyfill": "^0.12.0"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged && pnpm typecheck && pnpm test -- --run && pnpm exec esno scripts/validate-registries.ts"
  },
  "lint-staged": {
    "*.{ts,js,vue}": [
      "eslint --fix"
    ]
  }
}
