{
  "compilerOptions": {
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "module": "esnext",
    "target": "esnext",
    "lib": ["dom", "esnext"],
    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "incremental": false,
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "noUnusedLocals": true,
    "forceConsistentCasingInFileNames": true,
    "jsx": "preserve",
    "typeRoots": [
      "node_modules/@types",
      "src/types/"
    ],
    "types": [
      "vite/client",
      "chrome",
      "node",
    ],
    "paths": {
      "@/*": ["src/*"],
    }
  },
  "exclude": ["dist", "node_modules", "src/**/__tests__"],
  "include": [
    "src/**/*.ts",
    "src/**/*.d.ts",
    "src/**/*.vue",
    "scripts/**/*.ts"
  ]
}
